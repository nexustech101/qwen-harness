# agent-mcp environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to the agent-mcp data directory as ".env":
#
#   Linux   : ~/.local/share/agent-mcp/.env
#   macOS   : ~/Library/Application Support/agent-mcp/.env
#   Windows : %LOCALAPPDATA%\agent-mcp\.env
#
# Values here are overridden by environment variables (env vars > .env file).
# ─────────────────────────────────────────────────────────────────────────────


# ── Data directory override ───────────────────────────────────────────────────
# Override the auto-detected platform data dir (absolute path).
# Useful for portable installs or non-standard setups.
# AGENT_DATA_DIR=


# ── LLM provider ─────────────────────────────────────────────────────────────
# One of: ollama | openai | anthropic
AGENT_API_LLM_PROVIDER=ollama
AGENT_API_DEFAULT_MODEL=qwen2.5-coder:7b


# ── Ollama ────────────────────────────────────────────────────────────────────
AGENT_API_OLLAMA_HOST=http://127.0.0.1:11434


# ── OpenAI (required when LLM_PROVIDER=openai) ───────────────────────────────
# AGENT_API_OPENAI_API_KEY=sk-...
# AGENT_API_OPENAI_DEFAULT_MODEL=gpt-4o-mini


# ── Anthropic (required when LLM_PROVIDER=anthropic) ─────────────────────────
# AGENT_API_ANTHROPIC_API_KEY=sk-ant-...
# AGENT_API_ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-20241022


# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to <data_dir>/agent.db — only override if you need a custom path.
# AGENT_API_DATABASE_URL=sqlite:////absolute/path/to/agent.db


# ── API server ────────────────────────────────────────────────────────────────
AGENT_API_BASE_URL=http://127.0.0.1:8000
# AGENT_API_GLOBAL_RATE_LIMIT=200/minute


# ── Logging ───────────────────────────────────────────────────────────────────
AGENT_API_LOG_LEVEL=INFO
# AGENT_API_LOG_JSON=false
# Defaults to <data_dir>/logs/agent.log
# AGENT_LOG_FILE=


# ── CLI / agent shell ─────────────────────────────────────────────────────────
AGENT_DEFAULT_MODEL=qwen2.5-coder:7b
# AGENT_MAX_READ_LINES=500
# AGENT_MAX_READ_BYTES=50000
# AGENT_CONTEXT_SUMMARY_MAX_CHARS=12000
# AGENT_CONTEXT_LOG_MAX_CHARS=40000


# ── Workspaces ────────────────────────────────────────────────────────────────
# Defaults to <data_dir>/workspaces
# AGENT_WORKSPACE_HOME=


# ── Traces ────────────────────────────────────────────────────────────────────
# Defaults to <data_dir>/traces
# AGENT_TRACE_DIR=
